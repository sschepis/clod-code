{
  "name": "obotovs",
  "displayName": "Oboto VS",
  "description": "Multi-LLM AI coding assistant for VS Code",
  "version": "0.1.0",
  "publisher": "sschepis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sschepis/clodcode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "obotovs",
          "title": "Oboto VS",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "obotovs": [
        {
          "id": "obotovs.explorer",
          "name": "Explorer"
        },
        {
          "type": "webview",
          "id": "obotovs.chatPanel",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "obotovs.newSession",
        "title": "Oboto: New Session"
      },
      {
        "command": "obotovs.clearSession",
        "title": "Oboto: Clear Session"
      },
      {
        "command": "obotovs.switchModel",
        "title": "Oboto: Switch Model"
      },
      {
        "command": "obotovs.askAboutSelection",
        "title": "Ask Oboto VS About Selection"
      },
      {
        "command": "obotovs.focusChat",
        "title": "Oboto: Focus Chat",
        "icon": {
          "light": "assets/icon.png",
          "dark": "assets/icon.png"
        }
      },
      {
        "command": "obotovs.openSettings",
        "title": "Oboto: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "obotovs.showLogs",
        "title": "Oboto: Show Logs",
        "icon": "$(output)"
      },
      {
        "command": "obotovs.openSurface",
        "title": "Oboto: Open Surface"
      },
      {
        "command": "obotovs.newChat",
        "title": "Oboto: New Chat Window"
      },
      {
        "command": "obotovs.listChats",
        "title": "Oboto: List Chat Windows"
      },
      {
        "command": "obotovs.explainCode",
        "title": "Oboto: Explain Code"
      },
      {
        "command": "obotovs.refactorCode",
        "title": "Oboto: Refactor Code"
      },
      {
        "command": "obotovs.writeTests",
        "title": "Oboto: Write Tests"
      },
      {
        "command": "obotovs.refreshExplorer",
        "title": "Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "obotovs.explorer.openFile",
        "title": "Open"
      },
      {
        "command": "obotovs.explorer.deleteFile",
        "title": "Delete"
      },
      {
        "command": "obotovs.explorer.revealInFinder",
        "title": "Reveal in Finder"
      },
      {
        "command": "obotovs.explorer.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "obotovs.explorer.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "obotovs.explorer.cancelTask",
        "title": "Cancel",
        "icon": "$(debug-stop)"
      },
      {
        "command": "obotovs.explorer.copyTaskResult",
        "title": "Copy Result"
      },
      {
        "command": "obotovs.explorer.rerunTask",
        "title": "Re-run Task"
      },
      {
        "command": "obotovs.explorer.focusTask",
        "title": "Focus in Chat"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "obotovs.focusChat",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "obotovs.askAboutSelection",
          "when": "editorHasSelection",
          "group": "obotovs@1"
        },
        {
          "command": "obotovs.explainCode",
          "when": "editorHasSelection",
          "group": "obotovs@1"
        },
        {
          "command": "obotovs.refactorCode",
          "when": "editorHasSelection",
          "group": "obotovs@1"
        },
        {
          "command": "obotovs.writeTests",
          "when": "editorHasSelection",
          "group": "obotovs@1"
        }
      ],
      "view/item/context": [
        {
          "command": "obotovs.explorer.openFile",
          "when": "view == obotovs.explorer && viewItem =~ /File$/",
          "group": "navigation@1"
        },
        {
          "command": "obotovs.explorer.revealInFinder",
          "when": "view == obotovs.explorer && viewItem =~ /File$|Dir$|workspaceRoot|workspaceFile|directory/",
          "group": "navigation@2"
        },
        {
          "command": "obotovs.explorer.copyPath",
          "when": "view == obotovs.explorer && viewItem =~ /File$|Dir$|workspaceRoot|workspaceFile|directory/",
          "group": "copy@1"
        },
        {
          "command": "obotovs.explorer.copyRelativePath",
          "when": "view == obotovs.explorer && viewItem =~ /File$|Dir$|workspaceRoot|workspaceFile|directory/",
          "group": "copy@2"
        },
        {
          "command": "obotovs.explorer.deleteFile",
          "when": "view == obotovs.explorer && viewItem =~ /surfaceFile|routeFile|routeDir|skillFile|conversationFile|workspaceFile|directory/",
          "group": "danger@1"
        },
        {
          "command": "obotovs.explorer.focusTask",
          "when": "view == obotovs.explorer && viewItem =~ /^task/",
          "group": "navigation@1"
        },
        {
          "command": "obotovs.explorer.cancelTask",
          "when": "view == obotovs.explorer && viewItem == taskRunning",
          "group": "navigation@2"
        },
        {
          "command": "obotovs.explorer.copyTaskResult",
          "when": "view == obotovs.explorer && viewItem =~ /taskCompleted|taskFailed/",
          "group": "copy@1"
        },
        {
          "command": "obotovs.explorer.rerunTask",
          "when": "view == obotovs.explorer && viewItem =~ /taskCompleted|taskFailed/",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "obotovs.openSettings",
          "when": "view == obotovs.chatPanel",
          "group": "navigation@1"
        },
        {
          "command": "obotovs.showLogs",
          "when": "view == obotovs.chatPanel",
          "group": "navigation@2"
        },
        {
          "command": "obotovs.clearSession",
          "when": "view == obotovs.chatPanel",
          "group": "navigation@3"
        },
        {
          "command": "obotovs.refreshExplorer",
          "when": "view == obotovs.explorer",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "obotovs.focusChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "obotovs.newChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "view == obotovs.chatPanel"
      },
      {
        "command": "obotovs.explorer.deleteFile",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "focusedView == obotovs.explorer && listFocus"
      }
    ],
    "configuration": {
      "title": "Oboto VS",
      "properties": {
        "obotovs.providers": {
          "type": "object",
          "default": {},
          "markdownDescription": "Configured LLM providers. Each key is a unique provider ID, and the value describes how to connect.\n\n**Example:**\n```json\n{\n  \"my-anthropic\": {\n    \"type\": \"anthropic\",\n    \"label\": \"Anthropic\",\n    \"defaultModel\": \"claude-sonnet-4-20250514\"\n  },\n  \"my-openai\": {\n    \"type\": \"openai\",\n    \"label\": \"OpenAI\",\n    \"defaultModel\": \"gpt-4o\"\n  }\n}\n```\nAPI keys can be set here or via environment variables (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.).\n\nThe managed **Oboto Local** provider (Ollama) is always available without configuration.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["ollama", "lmstudio", "openai", "anthropic", "gemini", "vertex-gemini", "vertex-anthropic", "openrouter", "deepseek", "azure-openai", "vscode-lm"],
                "description": "Provider type"
              },
              "label": {
                "type": "string",
                "description": "Display name (auto-generated if omitted)"
              },
              "apiKey": {
                "type": "string",
                "description": "API key (prefer env vars)"
              },
              "baseUrl": {
                "type": "string",
                "description": "Base URL (only needed for self-hosted / Azure)"
              },
              "defaultModel": {
                "type": "string",
                "description": "Default model name"
              }
            },
            "required": ["type"]
          }
        },
        "obotovs.routing": {
          "type": "object",
          "default": {
            "triage": { "providerId": "oboto" },
            "executor": { "providerId": "oboto" }
          },
          "markdownDescription": "Route task roles to specific providers and models.\n\n**Roles:**\n- `triage` — quick classification (fast, cheap model)\n- `executor` — main task execution (powerful model)\n- `planner` — planning and architecture (falls back to executor if unset)\n- `summarizer` — compaction and summarization (falls back to executor if unset)\n\n**Example:**\n```json\n{\n  \"triage\": { \"providerId\": \"oboto\" },\n  \"executor\": { \"providerId\": \"my-anthropic\", \"model\": \"claude-sonnet-4-20250514\" }\n}\n```\nUse `\"oboto\"` for the managed local Ollama provider, or a key from your `providers` map.",
          "properties": {
            "triage": {
              "type": "object",
              "properties": {
                "providerId": { "type": "string", "description": "Provider ID from providers map, or \"oboto\"" },
                "model": { "type": "string", "description": "Model name (falls back to provider's defaultModel)" }
              },
              "required": ["providerId"]
            },
            "executor": {
              "type": "object",
              "properties": {
                "providerId": { "type": "string" },
                "model": { "type": "string" }
              },
              "required": ["providerId"]
            },
            "planner": {
              "type": "object",
              "properties": {
                "providerId": { "type": "string" },
                "model": { "type": "string" }
              },
              "required": ["providerId"]
            },
            "summarizer": {
              "type": "object",
              "properties": {
                "providerId": { "type": "string" },
                "model": { "type": "string" }
              },
              "required": ["providerId"]
            }
          },
          "additionalProperties": false
        },
        "obotovs.permissionMode": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace-write",
            "full-access",
            "prompt"
          ],
          "default": "prompt",
          "description": "Permission mode for tool execution"
        },
        "obotovs.maxIterations": {
          "type": "number",
          "default": 25,
          "description": "Maximum tool-use iterations per turn"
        },
        "obotovs.maxContextTokens": {
          "type": "number",
          "default": 128000,
          "description": "Maximum context window tokens"
        },
        "obotovs.triageEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable dual-LLM triage (local for simple queries, remote for complex tasks)"
        },
        "obotovs.autoCompact": {
          "type": "boolean",
          "default": true,
          "description": "Automatically compact sessions when token limit is approached"
        },
        "obotovs.autoCompactThreshold": {
          "type": "number",
          "default": 150000,
          "description": "Token count threshold for auto-compaction"
        },
        "obotovs.instructionFile": {
          "type": "string",
          "default": "CLAUDE.md",
          "description": "Name of the project instruction file"
        },
        "obotovs.maxConcurrentAgents": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum background agents that may run at once"
        },
        "obotovs.defaultAgentBudgetUsd": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "description": "Default USD budget ceiling for spawned background agents"
        },
        "obotovs.agentTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 1000,
          "description": "Default timeout (ms) for spawned background agents"
        },
        "obotovs.maxAgentNestingDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Maximum nesting depth for recursive agent spawning (0 = no sub-agents from background agents)"
        },
        "obotovs.surfacesAutoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Allow the AI to open surface panels on its own after creating or updating them. When off, open surfaces manually via 'Oboto VS: Open Surface'."
        },
        "obotovs.uiControlEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Allow the AI to capture screenshots and drive the mouse/keyboard via nut.js. On macOS you must also grant VS Code Screen Recording and Accessibility permissions in System Settings."
        },
        "obotovs.peerDispatchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow other Oboto VS windows on this workspace to send you dispatch/ask/cancel requests (each still requires your explicit approval in the UI). Turn off to ignore peer requests entirely."
        },
        "obotovs.shell": {
          "type": "string",
          "default": "",
          "enum": ["", "/bin/zsh", "/bin/bash", "/bin/sh"],
          "enumDescriptions": [
            "Auto-detect (uses $SHELL or system default)",
            "Zsh",
            "Bash",
            "POSIX sh"
          ],
          "description": "Shell to use for tool commands. Leave empty to auto-detect from $SHELL."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "obotovs.welcome",
        "title": "Welcome to Oboto VS",
        "description": "Get started with your multi-LLM AI coding assistant.",
        "steps": [
          {
            "id": "obotovs.step1",
            "title": "Start a Chat",
            "description": "Open the Oboto VS chat panel from the Activity Bar to start talking to your assistant. \n[Open Chat](command:obotovs.focusChat)",
            "media": {
              "markdown": "assets/walkthrough-chat.md"
            }
          },
          {
            "id": "obotovs.step2",
            "title": "Configure Your Models",
            "description": "Oboto VS supports OpenAI, Anthropic, Gemini, and local models. Set your API keys and default provider in the settings.\n[Open Settings](command:obotovs.openSettings)",
            "media": {
              "markdown": "assets/walkthrough-models.md"
            }
          },
          {
            "id": "obotovs.step3",
            "title": "Surfaces & Routes",
            "description": "Oboto VS can generate interactive Web UIs (Surfaces) and local API endpoints (Routes) directly inside your workspace.",
            "media": {
              "markdown": "assets/walkthrough-surfaces.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "webpack --mode production",
    "build:webview": "cd webview-ui && npm run build",
    "dev": "concurrently \"webpack --mode development --watch\" \"cd webview-ui && npm run dev\"",
    "watch": "webpack --mode development --watch",
    "prepackage": "node scripts/prepackage.js",
    "package": "npm run build && npm run prepackage && vsce package --no-dependencies",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "postinstall": "node scripts/patch-oboto-agent.js"
  },
  "dependencies": {
    "@aleph-ai/tinyaleph": "^1.7.3",
    "@anthropic-ai/sdk": "^0.30.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.21.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@sschepis/as-agent": "^0.1.2",
    "@sschepis/llm-wrapper": "^0.1.7",
    "@sschepis/lmscript": "^0.1.3",
    "@sschepis/oboto-agent": "file:../oboto-agent",
    "@sschepis/swiss-army-tool": "^0.1.2",
    "@xenova/transformers": "^2.17.2",
    "openai": "^4.104.0",
    "web-tree-sitter": "^0.26.8",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "icon": "assets/icon.png",
  "keywords": [
    "ai",
    "copilot",
    "llm",
    "chat",
    "agents",
    "coding assistant"
  ],
  "bugs": {
    "url": "https://github.com/sschepis/obotovs/issues"
  },
  "homepage": "https://github.com/sschepis/obotovs#readme"
}