{
  "name": "clodcode",
  "displayName": "Clod Code",
  "description": "Multi-LLM AI coding assistant for VS Code",
  "version": "0.1.0",
  "publisher": "sschepis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sschepis/clodcode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clodcode",
          "title": "Clod Code",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "clodcode": [
        {
          "id": "clodcode.explorer",
          "name": "Explorer"
        },
        {
          "type": "webview",
          "id": "clodcode.chatPanel",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "clodcode.newSession",
        "title": "Clod Code: New Session"
      },
      {
        "command": "clodcode.clearSession",
        "title": "Clod Code: Clear Session"
      },
      {
        "command": "clodcode.switchModel",
        "title": "Clod Code: Switch Model"
      },
      {
        "command": "clodcode.askAboutSelection",
        "title": "Ask Clod Code About Selection"
      },
      {
        "command": "clodcode.focusChat",
        "title": "Clod Code: Focus Chat",
        "icon": {
          "light": "assets/icon.png",
          "dark": "assets/icon.png"
        }
      },
      {
        "command": "clodcode.openSettings",
        "title": "Clod Code: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "clodcode.showLogs",
        "title": "Clod Code: Show Logs",
        "icon": "$(output)"
      },
      {
        "command": "clodcode.openSurface",
        "title": "Clod Code: Open Surface"
      },
      {
        "command": "clodcode.newChat",
        "title": "Clod Code: New Chat Window"
      },
      {
        "command": "clodcode.listChats",
        "title": "Clod Code: List Chat Windows"
      },
      {
        "command": "clodcode.explainCode",
        "title": "Clod Code: Explain Code"
      },
      {
        "command": "clodcode.refactorCode",
        "title": "Clod Code: Refactor Code"
      },
      {
        "command": "clodcode.writeTests",
        "title": "Clod Code: Write Tests"
      },
      {
        "command": "clodcode.refreshExplorer",
        "title": "Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "clodcode.explorer.openFile",
        "title": "Open"
      },
      {
        "command": "clodcode.explorer.deleteFile",
        "title": "Delete"
      },
      {
        "command": "clodcode.explorer.revealInFinder",
        "title": "Reveal in Finder"
      },
      {
        "command": "clodcode.explorer.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "clodcode.explorer.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "clodcode.explorer.cancelTask",
        "title": "Cancel",
        "icon": "$(debug-stop)"
      },
      {
        "command": "clodcode.explorer.copyTaskResult",
        "title": "Copy Result"
      },
      {
        "command": "clodcode.explorer.rerunTask",
        "title": "Re-run Task"
      },
      {
        "command": "clodcode.explorer.focusTask",
        "title": "Focus in Chat"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "clodcode.focusChat",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "clodcode.askAboutSelection",
          "when": "editorHasSelection",
          "group": "clodcode@1"
        },
        {
          "command": "clodcode.explainCode",
          "when": "editorHasSelection",
          "group": "clodcode@1"
        },
        {
          "command": "clodcode.refactorCode",
          "when": "editorHasSelection",
          "group": "clodcode@1"
        },
        {
          "command": "clodcode.writeTests",
          "when": "editorHasSelection",
          "group": "clodcode@1"
        }
      ],
      "view/item/context": [
        {
          "command": "clodcode.explorer.openFile",
          "when": "view == clodcode.explorer && viewItem =~ /File$/",
          "group": "navigation@1"
        },
        {
          "command": "clodcode.explorer.revealInFinder",
          "when": "view == clodcode.explorer && viewItem =~ /File$|Dir$|workspaceRoot|workspaceFile|directory/",
          "group": "navigation@2"
        },
        {
          "command": "clodcode.explorer.copyPath",
          "when": "view == clodcode.explorer && viewItem =~ /File$|Dir$|workspaceRoot|workspaceFile|directory/",
          "group": "copy@1"
        },
        {
          "command": "clodcode.explorer.copyRelativePath",
          "when": "view == clodcode.explorer && viewItem =~ /File$|Dir$|workspaceRoot|workspaceFile|directory/",
          "group": "copy@2"
        },
        {
          "command": "clodcode.explorer.deleteFile",
          "when": "view == clodcode.explorer && viewItem =~ /surfaceFile|routeFile|routeDir|skillFile|conversationFile|workspaceFile|directory/",
          "group": "danger@1"
        },
        {
          "command": "clodcode.explorer.focusTask",
          "when": "view == clodcode.explorer && viewItem =~ /^task/",
          "group": "navigation@1"
        },
        {
          "command": "clodcode.explorer.cancelTask",
          "when": "view == clodcode.explorer && viewItem == taskRunning",
          "group": "navigation@2"
        },
        {
          "command": "clodcode.explorer.copyTaskResult",
          "when": "view == clodcode.explorer && viewItem =~ /taskCompleted|taskFailed/",
          "group": "copy@1"
        },
        {
          "command": "clodcode.explorer.rerunTask",
          "when": "view == clodcode.explorer && viewItem =~ /taskCompleted|taskFailed/",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "clodcode.openSettings",
          "when": "view == clodcode.chatPanel",
          "group": "navigation@1"
        },
        {
          "command": "clodcode.showLogs",
          "when": "view == clodcode.chatPanel",
          "group": "navigation@2"
        },
        {
          "command": "clodcode.clearSession",
          "when": "view == clodcode.chatPanel",
          "group": "navigation@3"
        },
        {
          "command": "clodcode.refreshExplorer",
          "when": "view == clodcode.explorer",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "clodcode.focusChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "clodcode.newChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "view == clodcode.chatPanel"
      },
      {
        "command": "clodcode.explorer.deleteFile",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "focusedView == clodcode.explorer && listFocus"
      }
    ],
    "configuration": {
      "title": "Clodcode",
      "properties": {
        "clodcode.localProvider": {
          "type": "string",
          "enum": [
            "ollama",
            "lmstudio",
            "openai",
            "anthropic",
            "gemini",
            "vertex-gemini",
            "vertex-anthropic",
            "openrouter",
            "deepseek",
            "azure-openai"
          ],
          "default": "ollama",
          "description": "LLM provider for the local (triage) model"
        },
        "clodcode.localModel": {
          "type": "string",
          "default": "llama3:8b",
          "description": "Model name for the local provider"
        },
        "clodcode.localBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for the local provider"
        },
        "clodcode.localApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the local provider when it's a commercial LLM (prefer env vars: ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_AI_API_KEY, etc.)"
        },
        "clodcode.remoteProvider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai",
            "gemini",
            "vertex-gemini",
            "vertex-anthropic",
            "openrouter",
            "deepseek",
            "azure-openai",
            "ollama",
            "lmstudio"
          ],
          "default": "anthropic",
          "description": "LLM provider for the remote (powerful) model"
        },
        "clodcode.remoteModel": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Model name for the remote provider"
        },
        "clodcode.remoteApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the remote provider (prefer env vars: ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.)"
        },
        "clodcode.remoteBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL / endpoint for the remote provider. Required for Azure OpenAI (e.g. https://myresource.openai.azure.com). Optional for other providers."
        },
        "clodcode.providerKeys": {
          "type": "object",
          "default": {},
          "description": "API keys for multiple providers. Keys are provider names (e.g. 'anthropic', 'openai'), values are API key strings. Enables quick model switching from the chat header.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "clodcode.permissionMode": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace-write",
            "full-access",
            "prompt"
          ],
          "default": "prompt",
          "description": "Permission mode for tool execution"
        },
        "clodcode.maxIterations": {
          "type": "number",
          "default": 25,
          "description": "Maximum tool-use iterations per turn"
        },
        "clodcode.maxContextTokens": {
          "type": "number",
          "default": 128000,
          "description": "Maximum context window tokens"
        },
        "clodcode.triageEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable dual-LLM triage (local for simple queries, remote for complex tasks)"
        },
        "clodcode.autoCompact": {
          "type": "boolean",
          "default": true,
          "description": "Automatically compact sessions when token limit is approached"
        },
        "clodcode.autoCompactThreshold": {
          "type": "number",
          "default": 150000,
          "description": "Token count threshold for auto-compaction"
        },
        "clodcode.instructionFile": {
          "type": "string",
          "default": "CLAUDE.md",
          "description": "Name of the project instruction file"
        },
        "clodcode.maxConcurrentAgents": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum background agents that may run at once"
        },
        "clodcode.defaultAgentBudgetUsd": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "description": "Default USD budget ceiling for spawned background agents"
        },
        "clodcode.agentTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 1000,
          "description": "Default timeout (ms) for spawned background agents"
        },
        "clodcode.maxAgentNestingDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Maximum nesting depth for recursive agent spawning (0 = no sub-agents from background agents)"
        },
        "clodcode.surfacesAutoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Allow the AI to open surface panels on its own after creating or updating them. When off, open surfaces manually via 'Clodcode: Open Surface'."
        },
        "clodcode.uiControlEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Allow the AI to capture screenshots and drive the mouse/keyboard via nut.js. On macOS you must also grant VS Code Screen Recording and Accessibility permissions in System Settings."
        },
        "clodcode.peerDispatchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow other Clodcode windows on this workspace to send you dispatch/ask/cancel requests (each still requires your explicit approval in the UI). Turn off to ignore peer requests entirely."
        },
        "clodcode.promptRouting": {
          "type": "object",
          "default": {
            "orchestrator": { "provider": "gemini", "model": "gemini-3-flash-preview" },
            "planner": { "provider": "gemini", "model": "gemini-3.1-pro-preview" },
            "actor": { "provider": "gemini", "model": "gemini-3-flash-preview" },
            "summarizer": { "provider": "local", "model": "" }
          },
          "markdownDescription": "Route different task roles to specific providers and models. Each role maps to `{ \"provider\": \"...\", \"model\": \"...\" }`.\n\n**Roles:**\n- `orchestrator` — triage/routing decisions (fast, cheap model)\n- `planner` — planning and architecture (strong reasoning model)\n- `actor` — execution and tool use (main workhorse model)\n- `summarizer` — compaction and summarization\n\n**Example:**\n```json\n{\n  \"orchestrator\": { \"provider\": \"anthropic\", \"model\": \"claude-haiku-4-5-20251001\" },\n  \"planner\": { \"provider\": \"anthropic\", \"model\": \"claude-sonnet-4-20250514\" },\n  \"actor\": { \"provider\": \"openai\", \"model\": \"gpt-4o\" }\n}\n```\nUnconfigured roles fall back to the default local/remote provider settings.",
          "properties": {
            "orchestrator": {
              "type": "object",
              "properties": {
                "provider": { "type": "string", "description": "Provider name (e.g. anthropic, openai, gemini)" },
                "model": { "type": "string", "description": "Model name for this provider" }
              },
              "required": ["provider", "model"],
              "description": "Triage/routing decisions — a fast, cheap model works well here"
            },
            "planner": {
              "type": "object",
              "properties": {
                "provider": { "type": "string" },
                "model": { "type": "string" }
              },
              "required": ["provider", "model"],
              "description": "Planning and architecture — use a strong reasoning model"
            },
            "actor": {
              "type": "object",
              "properties": {
                "provider": { "type": "string" },
                "model": { "type": "string" }
              },
              "required": ["provider", "model"],
              "description": "Execution and tool use — the main workhorse model"
            },
            "summarizer": {
              "type": "object",
              "properties": {
                "provider": { "type": "string" },
                "model": { "type": "string" }
              },
              "required": ["provider", "model"],
              "description": "Compaction and summarization tasks. Set provider to \"local\" to use the configured local LLM (Ollama/LM Studio)."
            }
          },
          "additionalProperties": false
        },
        "clodcode.roundRobinEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Rotate the remote provider across all configured providers on each request. Requires roundRobinModels to map each provider to a model name."
        },
        "clodcode.roundRobinModels": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "Per-provider model names for round-robin rotation. Example: { \"anthropic\": \"claude-sonnet-4-20250514\", \"openai\": \"gpt-4o\", \"gemini\": \"gemini-2.0-flash\" }. Only providers listed here (with valid API keys) participate in rotation."
        },
        "clodcode.shell": {
          "type": "string",
          "default": "",
          "enum": ["", "/bin/zsh", "/bin/bash", "/bin/sh"],
          "enumDescriptions": [
            "Auto-detect (uses $SHELL or system default)",
            "Zsh",
            "Bash",
            "POSIX sh"
          ],
          "description": "Shell to use for tool commands. Leave empty to auto-detect from $SHELL."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "clodcode.welcome",
        "title": "Welcome to Clod Code",
        "description": "Get started with your multi-LLM AI coding assistant.",
        "steps": [
          {
            "id": "clodcode.step1",
            "title": "Start a Chat",
            "description": "Open the Clod Code chat panel from the Activity Bar to start talking to your assistant. \n[Open Chat](command:clodcode.focusChat)",
            "media": {
              "markdown": "assets/walkthrough-chat.md"
            }
          },
          {
            "id": "clodcode.step2",
            "title": "Configure Your Models",
            "description": "Clod Code supports OpenAI, Anthropic, Gemini, and local models. Set your API keys and default provider in the settings.\n[Open Settings](command:clodcode.openSettings)",
            "media": {
              "markdown": "assets/walkthrough-models.md"
            }
          },
          {
            "id": "clodcode.step3",
            "title": "Surfaces & Routes",
            "description": "Clod Code can generate interactive Web UIs (Surfaces) and local API endpoints (Routes) directly inside your workspace.",
            "media": {
              "markdown": "assets/walkthrough-surfaces.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "webpack --mode production",
    "build:webview": "cd webview-ui && npm run build",
    "dev": "concurrently \"webpack --mode development --watch\" \"cd webview-ui && npm run dev\"",
    "watch": "webpack --mode development --watch",
    "prepackage": "node scripts/prepackage.js",
    "package": "npm run build && npm run prepackage && vsce package --no-dependencies",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "postinstall": "node scripts/patch-oboto-agent.js"
  },
  "dependencies": {
    "@aleph-ai/tinyaleph": "^1.7.3",
    "@anthropic-ai/sdk": "^0.30.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.21.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@sschepis/as-agent": "^0.1.2",
    "@sschepis/llm-wrapper": "^0.1.7",
    "@sschepis/lmscript": "^0.1.3",
    "@sschepis/oboto-agent": "file:../oboto-agent",
    "@sschepis/swiss-army-tool": "^0.1.2",
    "@xenova/transformers": "^2.17.2",
    "openai": "^4.104.0",
    "web-tree-sitter": "^0.26.8",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "icon": "assets/icon.png",
  "keywords": [
    "ai",
    "copilot",
    "llm",
    "chat",
    "agents",
    "coding assistant"
  ],
  "bugs": {
    "url": "https://github.com/sschepis/clodcode/issues"
  },
  "homepage": "https://github.com/sschepis/clodcode#readme"
}